generator client {
  provider = "prisma-client-js"
} 

// Entity Schema 

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LINK
  OTHER
}

enum ClaimType {
  FACTUAL
  CAUSAL
  MECHANISTIC
  STATISTICAL
  ANECDOTAL
  RECOMMENDATION
  OTHER
} 



enum ClaimStance {
  SUPPORTS
  OPPOSES 
  ASSERTED 
  NEUTRAL
  MIXED
  UNKNOWN
}

enum ClaimConfidence {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
  UNKNOWN
}  

enum ClaimType { 
    SAFETY_RISK 
    OTHER  
    // need to add these in 
}

enum OrganizationType {
  BRAND
  MANUFACTURER
  RETAILER
  LAB
  CLINIC
  RESEARCH_INSTITUTION
  NONPROFIT
  MEDIA
  SPONSOR
  HOLDING_COMPANY
  OTHER
}

model Podcast {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  subtitle      String?
  description   String?
  rssUrl        String?
  websiteUrl    String?
  hostName      String?
  language      String?
  isPublished   Boolean   @default(false)

  episodes      Episode[]
  media         Media[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([title])
}

model Episode {
  id                  String         @id @default(cuid())
  slug                String         @unique
  podcastId           String
  podcast             Podcast        @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  title               String
  episodeNumber       Int?
  seasonNumber        Int?
  summary             String?
  description         String?
  transcript          String?
  transcriptSourceUrl String?
  audioUrl            String?
  videoUrl            String?
  publishedAt         DateTime?
  durationSeconds     Int?
  isPublished         Boolean        @default(false)

  sponsorOrganizations Organization[] @relation("EpisodeSponsors")
  guests               Person[]       @relation("EpisodeGuests")
  claims               Claim[]
  media                Media[]

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([podcastId])
  @@index([publishedAt])
  @@index([title])
  @@unique([podcastId, episodeNumber])
}

model Claim {
  id                String           @id @default(cuid())
  episodeId         String
  episode           Episode          @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  speakerId         String?
  speaker           Person?          @relation("ClaimSpeaker", fields: [speakerId], references: [id], onDelete: SetNull)

  text              String
  evidenceExcerpt   String?
  claimType         ClaimType        @default(OTHER)
  stance            ClaimStance      @default(UNKNOWN)
  claimConfidence   ClaimConfidence  @default(UNKNOWN)
  startTimeSeconds  Int?
  endTimeSeconds    Int?
  sourceUrl         String?

  media             Media[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([episodeId])
  @@index([speakerId])
  @@index([claimType])
  @@index([stance])
}

model Person {
  id                String        @id @default(cuid())
  slug              String        @unique
  fullName          String
  firstName         String?
  lastName          String?
  title             String?
  bio               String?
  websiteUrl        String?
  linkedinUrl       String?
  xUrl              String?

  guestEpisodes     Episode[]     @relation("EpisodeGuests")
  spokenClaims      Claim[]       @relation("ClaimSpeaker")

  ownedOrganizations     Organization[] @relation("OrganizationOwners")
  executiveOrganizations Organization[] @relation("OrganizationExecutives")

  media             Media[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([fullName])
}

model Organization {
  id                     String         @id @default(cuid())
  slug                   String         @unique
  name                   String
  legalName              String?
  description            String?
  websiteUrl             String?
  headquarters           String?
  foundedYear            Int?  
  annualRevenue          Float? 
  stockTicker            String?  
  employeeCount          Int? 
  organizationType       OrganizationType @default(OTHER)

  products               Product[]
  owners                 Person[]       @relation("OrganizationOwners")
  executives             Person[]       @relation("OrganizationExecutives")

  sponsoredEpisodes      Episode[]      @relation("EpisodeSponsors")
  referencedCaseStudies  CaseStudy[]    @relation("OrganizationReferencedCaseStudies")
  businessSponsoredCases CaseStudy[]    @relation("CaseStudyBusinessSponsors")   
  

  media                  Media[]

  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([name])
  @@index([organizationType])
}

model Product {
  id                String       @id @default(cuid())
  slug              String       @unique
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  isLabTestPanelDefinition Boolean? 
  name              String 
  recommendedUse    String? 
  description       String?
  category          String?
  sku               String?
  productUrl        String?
  price             Decimal?     @db.Decimal(10, 2)
  currency          String?      @default("USD")
  isActive          Boolean      @default(true)

  containsCompounds Compound[]
  labTests          LabTest[]
  media             Media[]

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId])
  @@index([name])
  @@index([sku])
  @@unique([organizationId, name])
}

model Compound {
  id                String      @id @default(cuid())
  slug              String      @unique
  name              String
  description       String?
  canonicalName     String?
  externalRef       String?

  products          Product[]
  biomarkers        Biomarker[] @relation("CompoundBiomarkerAssociations")
  media             Media[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([name])
}

model LabTest {
  id                String       @id @default(cuid())
  slug              String       @unique
  productId         String?
  product           Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  name              String
  description       String?
  labName           String?
  reportUrl         String?
  testedAt          DateTime?
  sampleType        String?

  testsBiomarkers   Biomarker[]  @relation("LabTestBiomarkers")
  media             Media[]

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([productId])
  @@index([organizationId])
  @@index([testedAt])
  @@index([name])
}

model Biomarker {
  id                String      @id @default(cuid())
  slug              String      @unique
  name              String
  description       String?
  unit              String?
  category          String?
  referenceRange    String?  
  referenceAgeMin   Int? 
  referenceAgeMax   Int? 
  referenceRangeLow Float? 
  referenceRangeMax Float? 

  labTests          LabTest[]   @relation("LabTestBiomarkers")
  compounds         Compound[]  @relation("CompoundBiomarkerAssociations")
  media             Media[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([name])
}

model CaseStudy {
  id                String         @id @default(cuid())
  slug              String         @unique
  title             String
  description       String?
  studyType         String?
  publicationDate   DateTime?
  sourceUrl         String?
  doi               String?
  journal           String?
  outcomeSummary    String? 
  fullTextSummary   String? 

  businessSponsors  Organization[] @relation("CaseStudyBusinessSponsors")
  referencedByOrganizations Organization[] @relation("OrganizationReferencedCaseStudies")

  media             Media[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([title])
  @@index([publicationDate])
  @@index([doi])
}

model Media {
  id                String     @id @default(cuid())
  url               String
  type              MediaType
  mimeType          String?
  title             String?
  altText           String?
  caption           String?
  width             Int?
  height            Int?
  durationSeconds   Int?
  fileSizeBytes     Int?
  sortOrder         Int         @default(0)

  podcastId         String?
  episodeId         String?
  claimId           String?
  personId          String?
  organizationId    String?
  productId         String?
  compoundId        String?
  labTestId         String?
  biomarkerId       String?
  caseStudyId       String?

  podcast           Podcast?      @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  episode           Episode?      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  claim             Claim?        @relation(fields: [claimId], references: [id], onDelete: Cascade)
  person            Person?       @relation(fields: [personId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product           Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  compound          Compound?     @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  labTest           LabTest?      @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  biomarker         Biomarker?    @relation(fields: [biomarkerId], references: [id], onDelete: Cascade)
  caseStudy         CaseStudy?    @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([podcastId])
  @@index([episodeId])
  @@index([claimId])
  @@index([personId])
  @@index([organizationId])
  @@index([productId])
  @@index([compoundId])
  @@index([labTestId])
  @@index([biomarkerId])
  @@index([caseStudyId])
  @@index([type])
}